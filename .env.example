# ============================================================
# ResearchRAG — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── LLM Provider ────────────────────────────────────────────
# Options: openai | claude | local
LLM_PROVIDER=openai

# ── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo

# ── Groq ──────────────────────────────────────────────────
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama3-70b-8192

# ── Anthropic / Claude ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-haiku-20240307

# ── Groq ────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
# Available models: llama3-70b-8192 | llama3-8b-8192 | mixtral-8x7b-32768 | gemma2-9b-it
GROQ_MODEL=llama3-70b-8192

# ── Embeddings ──────────────────────────────────────────────
# Model used for creating vector embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Retrieval ───────────────────────────────────────────────
TOP_K=5

# ── Chunking ────────────────────────────────────────────────
CHUNK_SIZE=700
CHUNK_OVERLAP=100

# ── Storage ─────────────────────────────────────────────────
FAISS_INDEX_PATH=storage/faiss_index/index.faiss
METADATA_PATH=storage/faiss_index/metadata.json
EVALUATION_LOG_PATH=storage/evaluation_log.csv
